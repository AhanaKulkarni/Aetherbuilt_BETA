<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AetherBuilt Beta Dashboard</title>
    
    <!-- 1. Load Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- 2. Load Babel to compile JSX in the browser -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <!-- 3. Setup Import Maps to pull React, Recharts, and Lucide Icons directly from the web -->
    <script type="importmap">
    {
        "imports": {
            "react": "https://esm.sh/react@18.3.1",
            "react-dom": "https://esm.sh/react-dom@18.3.1",
            "react-dom/client": "https://esm.sh/react-dom@18.3.1/client",
            "recharts": "https://esm.sh/recharts@2.12.3?external=react,react-dom",
            "lucide-react": "https://esm.sh/lucide-react@0.359.0?external=react,react-dom"
        }
    }
    </script>
</head>
<body class="bg-slate-50 text-slate-900 font-sans">
    
    <!-- This is where the React App will render -->
    <div id="root"></div>

    <!-- 4. The React Application Code -->
    <script type="text/babel" data-type="module">
        import React from 'react';
        import { createRoot } from 'react-dom/client';
        import { 
          BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, 
          PieChart, Pie, Cell, Legend
        } from 'recharts';
        import { 
          Users, Clock, Zap, IndianRupee, MapPin, 
          Factory, Heart, AlertTriangle, CheckCircle2, 
          Download, Filter, MessageSquare, Globe, WifiOff, Puzzle, Timer
        } from 'lucide-react';

        const COLORS = ['#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4'];

        const App = () => {
          // --------------------------------------------------------
          // DATA SECTION
          // --------------------------------------------------------

          const metrics = [
            { label: 'Active Beta Factories', value: '279', delta: '+12%', icon: Users, color: 'text-blue-600', bg: 'bg-blue-100', border: 'border-blue-200' },
            { label: 'Avg. Time Saved', value: '2.1 hrs', delta: 'Per Day', icon: Clock, color: 'text-emerald-600', bg: 'bg-emerald-100', border: 'border-emerald-200' },
            { label: 'Monthly OpEx Gain', value: '₹42,500', delta: '+8.4%', icon: IndianRupee, color: 'text-amber-600', bg: 'bg-amber-100', border: 'border-amber-200' },
            { label: 'Platform NPS', value: '8.8', delta: '/10 Score', icon: Heart, color: 'text-rose-600', bg: 'bg-rose-100', border: 'border-rose-200' },
          ];

          const majorBenefits = [
            { 
              profile: 'Medium Plastics Manufacturer • Mumbai', 
              metric: '₹2L Saved',
              benefit: 'Predicted motor failure, saved ₹2 Lakhs in potential downtime.', 
              feature: 'Maintenance Alerts',
            },
            { 
              profile: 'Large Auto Parts Facility • Vadodara', 
              metric: 'Zero Delays',
              benefit: 'Zero missed deadlines with clients since the Predictor went live.', 
              feature: 'Delay Predictor',
            },
            { 
              profile: 'Small Fabrication Plant • Kolhapur', 
              metric: 'High Trust',
              benefit: 'Client professionalism increased massively via instant reports.', 
              feature: 'Client Report Share',
            }
          ];

          const criticalRoadblocks = [
            {
              category: 'Language Barrier',
              priority: 'CRITICAL',
              icon: Globe,
              issues: ['Need Marathi UI for shop floor workers', 'Need Gujarati UI for regional adoption'],
              colorClass: 'bg-rose-50 border-rose-500 text-rose-900',
              iconClass: 'bg-rose-500 text-white'
            },
            {
              category: 'Hardware & Connectivity',
              priority: 'HIGH',
              icon: WifiOff,
              issues: ['Mobile app crashes on older Androids', 'Sync fails in basement factory setups'],
              colorClass: 'bg-amber-50 border-amber-500 text-amber-900',
              iconClass: 'bg-amber-500 text-white'
            },
            {
              category: 'Setup & Onboarding',
              priority: 'MEDIUM',
              icon: Timer,
              issues: ['Initial manual data entry takes 3+ days', 'Too complex for non-tech supervisors'],
              colorClass: 'bg-blue-50 border-blue-500 text-blue-900',
              iconClass: 'bg-blue-500 text-white'
            },
            {
              category: 'Missing Integrations',
              priority: 'LOW',
              icon: Puzzle,
              issues: ['Direct Tally export needed', 'GST calculation missing for procurement'],
              colorClass: 'bg-purple-50 border-purple-500 text-purple-900',
              iconClass: 'bg-purple-500 text-white'
            }
          ];

          const efficiencyData = [
            { task: 'Inventory Audit', manual: 120, aether: 15 },
            { task: 'Order Logging', manual: 45, aether: 8 },
            { task: 'Report Gen.', manual: 90, aether: 5 },
            { task: 'Machine Check', manual: 60, aether: 10 },
          ];

          const industryData = [
            { name: 'Fabrication', value: 45 },
            { name: 'Plastics', value: 28 },
            { name: 'Auto Parts', value: 18 },
            { name: 'Textiles', value: 9 },
          ];

          // --------------------------------------------------------
          // RENDER SECTION
          // --------------------------------------------------------

          return (
            <div className="min-h-screen bg-slate-50 text-slate-900 font-sans p-4 md:p-8">
              <div className="max-w-7xl mx-auto space-y-8">
                
                {/* --- Header --- */}
                <header className="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 bg-white p-6 rounded-2xl border-2 border-slate-200 shadow-sm">
                  <div className="flex items-center gap-4">
                    <div className="w-14 h-14 bg-slate-900 rounded-xl flex items-center justify-center text-white font-black text-2xl">
                      A
                    </div>
                    <div>
                      <h1 className="text-2xl font-black text-slate-900 tracking-tight">AetherBuilt Beta Dashboard</h1>
                      <p className="text-sm font-bold text-slate-500 mt-1 uppercase tracking-widest">Internal Data • 279 Facilities</p>
                    </div>
                  </div>
                  <div className="flex items-center gap-3">
                    <button className="flex items-center gap-2 px-5 py-2.5 bg-white border-2 border-slate-300 text-slate-700 rounded-xl font-bold hover:bg-slate-100 transition-colors">
                      <Filter size={18} /> Filter
                    </button>
                    <button className="flex items-center gap-2 px-5 py-2.5 bg-blue-600 border-2 border-blue-700 text-white rounded-xl font-bold hover:bg-blue-700 transition-colors">
                      <Download size={18} /> Export Data
                    </button>
                  </div>
                </header>

                {/* --- Top KPIs --- */}
                <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                  {metrics.map((m, i) => (
                    <div key={i} className="bg-white p-6 rounded-2xl border-2 border-slate-200 shadow-sm">
                      <div className="flex justify-between items-start mb-6">
                        <div className={`p-3 rounded-xl border ${m.bg} ${m.border} ${m.color}`}>
                          <m.icon size={24} strokeWidth={2.5} />
                        </div>
                        <span className="text-xs font-black px-3 py-1 rounded-lg border-2 border-slate-100 bg-slate-50 text-slate-600">
                          {m.delta}
                        </span>
                      </div>
                      <h3 className="text-3xl font-black text-slate-900 mb-1">{m.value}</h3>
                      <p className="text-xs font-bold text-slate-500 uppercase tracking-widest">{m.label}</p>
                    </div>
                  ))}
                </div>

                {/* --- SECTION 1: USER FEEDBACK (MOVED TO TOP) --- */}
                <section className="bg-white border-2 border-slate-200 rounded-2xl p-6 md:p-8 shadow-sm">
                  <div className="mb-8 border-b-2 border-slate-100 pb-4">
                    <h2 className="text-2xl font-black text-slate-900 flex items-center gap-3">
                      <MessageSquare className="text-blue-600" /> Core Beta Feedback
                    </h2>
                    <p className="text-sm font-semibold text-slate-500 mt-2">
                      Anonymized insights prioritizing immediate product roadmapping.
                    </p>
                  </div>

                  <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    
                    {/* Emphasized Roadblocks */}
                    <div className="space-y-4">
                      <h3 className="text-lg font-black text-slate-900 flex items-center gap-2 mb-4">
                        <AlertTriangle className="text-rose-500" />
                        Critical Friction Points
                      </h3>
                      {criticalRoadblocks.map((block, i) => (
                        <div key={i} className={`p-5 rounded-xl border-2 ${block.colorClass}`}>
                          <div className="flex items-center gap-4 mb-4">
                            <div className={`p-2.5 rounded-lg ${block.iconClass}`}>
                              <block.icon size={20} />
                            </div>
                            <div>
                              <h4 className="font-black uppercase tracking-wide text-sm">{block.category}</h4>
                              <span className="text-[10px] font-black uppercase bg-white/50 px-2 py-0.5 rounded border border-current opacity-80">
                                Priority: {block.priority}
                              </span>
                            </div>
                          </div>
                          <ul className="space-y-2">
                            {block.issues.map((issue, idx) => (
                              <li key={idx} className="flex items-start gap-2 text-sm font-bold opacity-90">
                                <span className="mt-0.5">•</span>
                                <span>{issue}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>

                    {/* Major Benefits */}
                    <div className="space-y-4">
                      <h3 className="text-lg font-black text-slate-900 flex items-center gap-2 mb-4">
                        <CheckCircle2 className="text-emerald-500" />
                        Major User Wins
                      </h3>
                      {majorBenefits.map((item, i) => (
                        <div key={i} className="p-5 bg-white border-2 border-slate-200 rounded-xl hover:border-emerald-500 transition-colors">
                          <div className="flex justify-between items-start mb-3">
                            <span className="text-xs font-black text-emerald-600 bg-emerald-50 px-3 py-1 rounded-md uppercase border border-emerald-200">
                              {item.metric}
                            </span>
                            <span className="text-[10px] font-bold text-slate-400 uppercase tracking-widest text-right">
                              {item.profile}
                            </span>
                          </div>
                          <p className="text-sm font-bold text-slate-800 mb-3">"{item.benefit}"</p>
                          <p className="text-[10px] font-bold text-slate-500 uppercase">
                            Key Feature: <span className="text-slate-900">{item.feature}</span>
                          </p>
                        </div>
                      ))}
                    </div>

                  </div>
                </section>

                {/* --- SECTION 2: CHARTS & METRICS --- */}
                <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                  
                  {/* Efficiency Bar Chart */}
                  <div className="bg-white p-6 md:p-8 rounded-2xl border-2 border-slate-200 shadow-sm">
                    <h2 className="text-xl font-black text-slate-900 flex items-center gap-2 mb-6">
                      <Zap className="text-amber-500" /> Time Saved: Manual vs AetherBuilt
                    </h2>
                    <div className="h-[300px]">
                      <ResponsiveContainer width="100%" height="100%">
                        <BarChart data={efficiencyData} layout="vertical" margin={{ left: 20, right: 20 }}>
                          <CartesianGrid strokeDasharray="3 3" horizontal={true} vertical={false} stroke="#e2e8f0" />
                          <XAxis type="number" hide />
                          <YAxis dataKey="task" type="category" axisLine={false} tickLine={false} tick={{fill: '#475569', fontSize: 12, fontWeight: 700}} width={100} />
                          <Tooltip 
                            cursor={{fill: '#f1f5f9'}}
                            contentStyle={{ borderRadius: '12px', border: '2px solid #e2e8f0', fontWeight: 'bold' }}
                          />
                          <Legend iconType="square" wrapperStyle={{ fontSize: '12px', fontWeight: 'bold', paddingTop: '10px' }}/>
                          <Bar dataKey="manual" name="Manual Method (mins)" fill="#94a3b8" radius={[0, 4, 4, 0]} barSize={28} />
                          <Bar dataKey="aether" name="AetherBuilt (mins)" fill="#3b82f6" radius={[0, 4, 4, 0]} barSize={28} />
                        </BarChart>
                      </ResponsiveContainer>
                    </div>
                  </div>

                  {/* Demographics & Industry */}
                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-6 bg-white p-6 md:p-8 rounded-2xl border-2 border-slate-200 shadow-sm">
                    
                    {/* Sector Split */}
                    <div>
                      <h3 className="text-lg font-black text-slate-900 flex items-center gap-2 mb-4">
                        <Factory className="text-indigo-500" size={20} /> Sector Split
                      </h3>
                      <div className="h-40 mb-6">
                        <ResponsiveContainer width="100%" height="100%">
                          <PieChart>
                            <Pie
                              data={industryData}
                              innerRadius={40}
                              outerRadius={70}
                              paddingAngle={4}
                              dataKey="value"
                              stroke="none"
                            >
                              {industryData.map((entry, index) => (
                                <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                              ))}
                            </Pie>
                            <Tooltip contentStyle={{ borderRadius: '8px', border: 'none', fontWeight: 'bold' }} />
                          </PieChart>
                        </ResponsiveContainer>
                      </div>
                      <div className="space-y-2">
                        {industryData.map((item, i) => (
                          <div key={i} className="flex justify-between items-center">
                            <div className="flex items-center gap-2">
                              <div className="w-3 h-3 rounded" style={{ backgroundColor: COLORS[i] }} />
                              <span className="text-xs font-bold text-slate-700">{item.name}</span>
                            </div>
                            <span className="text-xs font-black text-slate-900">{item.value}%</span>
                          </div>
                        ))}
                      </div>
                    </div>

                    {/* Regional Split */}
                    <div>
                      <h3 className="text-lg font-black text-slate-900 flex items-center gap-2 mb-4">
                        <MapPin className="text-rose-500" size={20} /> Regional Active
                      </h3>
                      <div className="space-y-5">
                        {[
                          { r: 'Mumbai', v: 85, color: 'bg-blue-500' },
                          { r: 'Vadodara', v: 62, color: 'bg-emerald-500' },
                          { r: 'Kolhapur', v: 48, color: 'bg-amber-500' },
                          { r: 'Rajkot', v: 35, color: 'bg-rose-500' },
                        ].map((item, i) => (
                          <div key={i}>
                            <div className="flex justify-between text-xs font-black text-slate-600 mb-1">
                              <span>{item.r}</span>
                              <span>{item.v}</span>
                            </div>
                            <div className="w-full bg-slate-100 h-2 rounded-full overflow-hidden border border-slate-200">
                              <div className={`h-full rounded-full ${item.color}`} style={{ width: `${(item.v / 85) * 100}%` }} />
                            </div>
                          </div>
                        ))}
                      </div>

                      <div className="mt-6 bg-slate-900 p-4 rounded-xl text-white border-2 border-slate-800">
                        <p className="text-[10px] font-black uppercase text-blue-400 mb-1">Conversion Signal</p>
                        <p className="text-xl font-black">65% Readiness</p>
                      </div>
                    </div>

                  </div>
                </div>

                <footer className="text-center py-6">
                  <p className="text-xs font-bold text-slate-400 uppercase tracking-widest">
                    AetherBuilt Operations Dashboard • Confidential
                  </p>
                </footer>

              </div>
            </div>
          );
        };

        // Render the app to the root element
        const rootElement = document.getElementById('root');
        const root = createRoot(rootElement);
        root.render(<App />);
    </script>
</body>
</html>